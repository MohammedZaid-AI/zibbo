# Copy to `.env` for local development. Every variable is optional; the
# defaults in gateway/config.py are development-safe.
#
# All settings are prefixed with LLMGATEWAY_ and map 1:1 onto Settings fields.

# --- Identity -----------------------------------------------------------
# development | test | staging | production
LLMGATEWAY_ENVIRONMENT=development

# --- Server -------------------------------------------------------------
LLMGATEWAY_HOST=0.0.0.0
LLMGATEWAY_PORT=8000
# Set when the gateway is mounted under a path prefix by a reverse proxy.
LLMGATEWAY_ROOT_PATH=

# --- Observability ------------------------------------------------------
# `debug` and a wildcard CORS origin are rejected in staging/production.
LLMGATEWAY_DEBUG=true
LLMGATEWAY_LOG_LEVEL=INFO
# console for humans, json for log aggregators
LLMGATEWAY_LOG_FORMAT=console

# --- HTTP ---------------------------------------------------------------
# Comma-separated or a JSON array. Empty disables CORS entirely.
LLMGATEWAY_CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Upstream transport -------------------------------------------------
LLMGATEWAY_UPSTREAM_CONNECT_TIMEOUT_SECONDS=10.0
LLMGATEWAY_UPSTREAM_READ_TIMEOUT_SECONDS=120.0
LLMGATEWAY_UPSTREAM_WRITE_TIMEOUT_SECONDS=30.0
LLMGATEWAY_UPSTREAM_POOL_TIMEOUT_SECONDS=10.0
LLMGATEWAY_UPSTREAM_MAX_CONNECTIONS=200
LLMGATEWAY_UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=50

# --- Providers ----------------------------------------------------------
LLMGATEWAY_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional fallback credential, used ONLY when the caller sends no Authorization
# header. A caller's own key always wins, so an existing app can switch over by
# changing base_url alone and keep billing to its own account.
# LLMGATEWAY_OPENAI_API_KEY=sk-...

# --- Backing services ---------------------------------------------------
# Unused until Phase 4 (Postgres) and Phase 8 (Redis).
LLMGATEWAY_DATABASE_URL=postgresql://llmgateway:llmgateway@localhost:5432/llmgateway
LLMGATEWAY_REDIS_URL=redis://localhost:6379/0

# --- Optimization -------------------------------------------------------
# Set to false for a pure Phase 2 passthrough: bodies cross byte-for-byte.
LLMGATEWAY_OPTIMIZATION_ENABLED=true

# Bodies above this are forwarded untouched rather than parsed.
LLMGATEWAY_OPTIMIZATION_MAX_BODY_BYTES=8000000

# Above this, transformation runs in a worker thread instead of the event loop.
LLMGATEWAY_OPTIMIZATION_OFFLOAD_THRESHOLD_BYTES=131072
LLMGATEWAY_OPTIMIZATION_MIN_SEGMENT_CHARS=0

# Off by default: `{"tools": []}` does not mean the same thing as `{}`.
LLMGATEWAY_JSON_REMOVE_EMPTY_CONTAINERS=false

# Off by default: collapsing runs of spaces destroys code indentation and
# Markdown table alignment, which are meaning rather than noise.
LLMGATEWAY_TEXT_COLLAPSE_INLINE_WHITESPACE=false
LLMGATEWAY_TEXT_DEDUPE_CONSECUTIVE_PARAGRAPHS=true

# URLs are content. Dropping them saves tokens by destroying information.
LLMGATEWAY_HTML_PRESERVE_LINKS=true
LLMGATEWAY_HTML_PRESERVE_IMAGES=true

# --- Tokenizer ----------------------------------------------------------
# auto: prefer tiktoken, fall back to the offline heuristic counter if its
# encoding files cannot be loaded. tiktoken | heuristic force one.
LLMGATEWAY_TOKENIZER=auto
LLMGATEWAY_TOKENIZER_DEFAULT_ENCODING=o200k_base

# Where tiktoken caches downloaded encodings. Baked into the Docker image at
# build time so the runtime never reaches for the network.
# TIKTOKEN_CACHE_DIR=/opt/tiktoken

# --- Health -------------------------------------------------------------
LLMGATEWAY_HEALTH_CHECK_TIMEOUT_SECONDS=2.0
