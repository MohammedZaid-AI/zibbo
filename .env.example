# Copy to `.env` for local development. Every variable is optional; the
# defaults in gateway/config.py are development-safe.
#
# All settings are prefixed with ZIBBO_ and map 1:1 onto Settings fields.

# --- Identity -----------------------------------------------------------
# development | test | staging | production
ZIBBO_ENVIRONMENT=development

# --- Server -------------------------------------------------------------
ZIBBO_HOST=0.0.0.0
ZIBBO_PORT=8000
# Set when the gateway is mounted under a path prefix by a reverse proxy.
ZIBBO_ROOT_PATH=

# --- Observability ------------------------------------------------------
# `debug` and a wildcard CORS origin are rejected in staging/production.
ZIBBO_DEBUG=true
ZIBBO_LOG_LEVEL=INFO
# console for humans, json for log aggregators
ZIBBO_LOG_FORMAT=console

# --- HTTP ---------------------------------------------------------------
# Comma-separated or a JSON array. Empty disables CORS entirely.
ZIBBO_CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Upstream transport -------------------------------------------------
ZIBBO_UPSTREAM_CONNECT_TIMEOUT_SECONDS=10.0
ZIBBO_UPSTREAM_READ_TIMEOUT_SECONDS=120.0
ZIBBO_UPSTREAM_WRITE_TIMEOUT_SECONDS=30.0
ZIBBO_UPSTREAM_POOL_TIMEOUT_SECONDS=10.0
ZIBBO_UPSTREAM_MAX_CONNECTIONS=200
ZIBBO_UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=50

# --- Providers ----------------------------------------------------------
# Each provider mounts at its own route prefix; a caller picks one by the URL its
# SDK points at. See docs/PROVIDERS.md. A configured key is used ONLY when the
# caller sends none — the caller's own credential always wins.

# OpenAI (SDK base_url -> <gateway>/v1)
ZIBBO_OPENAI_ENABLED=true
ZIBBO_OPENAI_PREFIX=/v1
ZIBBO_OPENAI_BASE_URL=https://api.openai.com/v1
# ZIBBO_OPENAI_API_KEY=sk-...

# Anthropic (SDK base_url -> <gateway>/anthropic; the SDK adds /v1 itself)
ZIBBO_ANTHROPIC_ENABLED=true
ZIBBO_ANTHROPIC_PREFIX=/anthropic
ZIBBO_ANTHROPIC_BASE_URL=https://api.anthropic.com
ZIBBO_ANTHROPIC_VERSION=2023-06-01
# ZIBBO_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible providers: enabled only when a base URL is set.
# ZIBBO_GROQ_BASE_URL=https://api.groq.com/openai/v1
# ZIBBO_GROQ_API_KEY=gsk_...
# ZIBBO_MISTRAL_BASE_URL=https://api.mistral.ai/v1
# ZIBBO_MISTRAL_API_KEY=...
# ZIBBO_OLLAMA_BASE_URL=http://localhost:11434/v1    # usually needs no key

# --- Backing services ---------------------------------------------------
# DATABASE_URL is unused until Phase 4 (Postgres). REDIS_URL is used by the
# transformation cache when CACHE_BACKEND=redis (below).
ZIBBO_DATABASE_URL=postgresql://zibbo:zibbo@localhost:5432/zibbo
ZIBBO_REDIS_URL=redis://localhost:6379/0

# --- Transformation cache -----------------------------------------------
# Identical documents/text segments are transformed once and reused. Caches only
# deterministic transformation OUTPUTS — never provider responses, never failed
# extractions. See docs/CACHE.md.
ZIBBO_CACHE_ENABLED=true

# memory (per-process, no dependency) or redis (shared across replicas; needs REDIS_URL).
ZIBBO_CACHE_BACKEND=memory

# Entry lifetime in seconds; 0 = no expiry. Deterministic output never goes stale, so
# a TTL only bounds a Redis keyspace — it is not needed for correctness.
ZIBBO_CACHE_TTL_SECONDS=0

# In-memory backend bounds: LRU eviction above either limit.
ZIBBO_CACHE_MAX_ENTRIES=2048
ZIBBO_CACHE_MAX_BYTES=128000000

# Redis key namespace, so one server can serve several deployments.
ZIBBO_CACHE_REDIS_PREFIX=zibbo:xform:

# --- Optimization -------------------------------------------------------
# Set to false for a pure Phase 2 passthrough: bodies cross byte-for-byte.
ZIBBO_OPTIMIZATION_ENABLED=true

# Bodies above this are forwarded untouched rather than parsed.
ZIBBO_OPTIMIZATION_MAX_BODY_BYTES=8000000

# Above this, transformation runs in a worker thread instead of the event loop.
ZIBBO_OPTIMIZATION_OFFLOAD_THRESHOLD_BYTES=131072
ZIBBO_OPTIMIZATION_MIN_SEGMENT_CHARS=0

# Off by default: `{"tools": []}` does not mean the same thing as `{}`.
ZIBBO_JSON_REMOVE_EMPTY_CONTAINERS=false

# Off by default: collapsing runs of spaces destroys code indentation and
# Markdown table alignment, which are meaning rather than noise.
ZIBBO_TEXT_COLLAPSE_INLINE_WHITESPACE=false
ZIBBO_TEXT_DEDUPE_CONSECUTIVE_PARAGRAPHS=true

# URLs are content. Dropping them saves tokens by destroying information.
ZIBBO_HTML_PRESERVE_LINKS=true
ZIBBO_HTML_PRESERVE_IMAGES=true

# --- Documents ----------------------------------------------------------
# Uploaded documents (PDF, DOCX, CSV, XML, HTML, Markdown) embedded as base64 in a
# request are extracted to Markdown before forwarding. On any failure the original
# is passed through unchanged. See docs/DOCUMENT_TRANSFORMERS.md.
ZIBBO_DOCUMENTS_ENABLED=true

# A decoded document larger than this is forwarded unparsed (base64 inflates ~1.33x).
ZIBBO_DOCUMENTS_MAX_DECODED_BYTES=16000000

# Formats to skip, comma-separated: pdf, docx, csv, xml, html, markdown, text.
# Disable pdf to keep a provider's native PDF vision, for example.
# ZIBBO_DOCUMENTS_DISABLED_FORMATS=

# --- Tokenizer ----------------------------------------------------------
# auto: prefer tiktoken, fall back to the offline heuristic counter if its
# encoding files cannot be loaded. tiktoken | heuristic force one.
ZIBBO_TOKENIZER=auto
ZIBBO_TOKENIZER_DEFAULT_ENCODING=o200k_base

# Where tiktoken caches downloaded encodings. Baked into the Docker image at
# build time so the runtime never reaches for the network.
# TIKTOKEN_CACHE_DIR=/opt/tiktoken

# --- Plugins ------------------------------------------------------------
# Transformers packaged separately and discovered at startup. A broken plugin is
# recorded and skipped; it never prevents the gateway from starting.
# See docs/PLUGIN_DEVELOPMENT.md and GET /internal/plugins.
ZIBBO_PLUGINS_ENABLED=true

# Installed packages advertising a transformer here. Set empty to skip entry points.
ZIBBO_PLUGINS_ENTRY_POINT_GROUP=zibbo.transformers

# Executes arbitrary code from the filesystem, so there is deliberately no default.
# ZIBBO_PLUGINS_DIR=/opt/zibbo/plugins

# Explicit `module:ATTR` targets. Highest precedence, so an operator can override
# an installed plugin. Comma-separated or a JSON array.
# ZIBBO_PLUGINS_LOAD=my_package.plugin:PLUGIN

# Loaded and validated, but not attached to the pipeline.
# ZIBBO_PLUGINS_DISABLED=csv

# Plugins that declare they remove information a caller might miss.
ZIBBO_PLUGINS_ALLOW_LOSSY=false

# Per-plugin configuration. Each plugin sees only its own entry.
# ZIBBO_PLUGINS_CONFIG={"csv": {"delimiter": ";"}}

# --- Health -------------------------------------------------------------
ZIBBO_HEALTH_CHECK_TIMEOUT_SECONDS=2.0
